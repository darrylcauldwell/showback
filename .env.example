# Showback Configuration
# Copy to .env and adjust values for your environment

# Prometheus
SHOWBACK_PROMETHEUS_URL=http://showback-prometheus:9090

# Fixed monthly costs
SHOWBACK_DROPLET_COST=24.00
SHOWBACK_CLOUDFLARE_COST=0.00
SHOWBACK_DOMAIN_COST=1.02

# Cost allocation weights (must sum to 1.0)
SHOWBACK_CPU_WEIGHT=0.5
SHOWBACK_MEMORY_WEIGHT=0.5

# Host hardware specs (for What-If comparison)
SHOWBACK_HOST_VCPUS=2
SHOWBACK_HOST_MEMORY_GB=4
SHOWBACK_HOST_DISK_GB=80

# App boundaries — JSON mapping app name to list of container names
SHOWBACK_APP_BOUNDARIES={"evm": ["evm-backend", "evm-frontend", "evm-db"], "equicalendar": ["equicalendar"], "planespotter": ["planespotter-api", "planespotter-frontend", "planespotter-sync", "planespotter-db", "planespotter-cache"], "meweb": ["meweb"], "greenscope": ["greenscope"], "infrastructure": ["prometheus", "grafana", "loki", "promtail", "node-exporter", "cadvisor", "ntfy", "showback"]}

# App display names — JSON mapping internal name to friendly name
SHOWBACK_APP_DISPLAY_NAMES={"evm": "Equestrian Venue Manager", "equicalendar": "EquiCalendar", "planespotter": "Planespotter", "meweb": "dreamfold.dev", "greenscope": "GreenScope", "infrastructure": "Infrastructure"}

# Calculation interval in minutes
SHOWBACK_CALCULATION_INTERVAL_MINUTES=15

# Database
SHOWBACK_DATABASE_URL=sqlite+aiosqlite:///data/showback.db

# Logging
SHOWBACK_LOG_LEVEL=INFO
